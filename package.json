{
  "name": "eve-hyte-map",
  "version": "1.0.0",
  "description": "Single-app EVE Online kill activity display powered by zKillboard R2Z2.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch --watch-preserve-output --watch-path=src --watch-path=config --watch-path=data/systems.json --watch-path=data/edges.json --watch-path=data/regions.json src/server/index.js",
    "test": "node --test",
    "generate:map": "node scripts/generate-map-data.mjs"
  },
  "keywords": [
    "eve-online",
    "zkillboard",
    "sse",
    "canvas"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1"
  }
}
